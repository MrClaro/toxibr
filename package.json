{
  "name": "toxibr",
  "version": "1.1.0",
  "description": "Biblioteca de moderação de conteúdo para português brasileiro. Filtro com wordlist 200+ termos, detecção context-aware, normalização anti-bypass e bloqueio de links/telefones.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "validate": "ts-node scripts/validate-wordlists.ts",
    "build:demo": "esbuild src/browser.ts --bundle --minify --outfile=docs/toxibr.min.js --format=iife",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "content-filter",
    "moderation",
    "profanity",
    "portuguese",
    "brazilian",
    "pt-br",
    "nsfw",
    "toxicity",
    "wordlist",
    "filter"
  ],
  "author": "Diaum",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/horacio3m/toxibr"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
